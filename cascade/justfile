# Cascade — Typst typography library. Local development helpers.

# Default recipe: list available recipes.
default:
    @just --list

# Read package name and version from typst.toml.
_meta := `awk -F'[ "=]+' '/^name *=/{n=$2} /^version *=/{v=$2} END{print n" "v}' typst.toml`

# Symlink this directory into Typst's local-package namespace so
# `#import "@local/cascade:0.1.0": ..."` resolves to the working tree.
# Idempotent — re-running replaces an existing symlink at the same target.
link:
    #!/usr/bin/env bash
    set -euo pipefail
    read -r name version <<< "{{ _meta }}"
    target="$HOME/.local/share/typst/packages/local/$name/$version"
    mkdir -p "$(dirname "$target")"
    ln -snf "$PWD" "$target"
    echo "Linked $PWD → $target"

# Remove the symlink installed by `just link`. Safe to run if absent.
unlink:
    #!/usr/bin/env bash
    set -euo pipefail
    read -r name version <<< "{{ _meta }}"
    target="$HOME/.local/share/typst/packages/local/$name/$version"
    if [[ -L "$target" ]]; then
        rm "$target"
        echo "Removed $target"
    else
        echo "No symlink at $target"
    fi

# Compile the usage sample to PDF.
sample:
    typst compile sample.typ

# Compile the scale-comparison sheet to PDF.
compare:
    typst compile scale-comparison.typ
